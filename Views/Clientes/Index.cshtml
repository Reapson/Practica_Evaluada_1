@model List<Practica_Evaluada_1.Models.Cliente>

@{
    ViewData["Title"] = "Listado de clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Listado de clientes</h1>
        <p class="text-muted mb-0">Clientes registrados y numeros de telefono asociados.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Clientes" asp-action="Registrar">Registrar cliente</a>
</div>

@if (TempData["Mensaje"] is not null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Cedula</th>
                <th>Nombre completo</th>
                <th>Correo electronico</th>
                <th>Direccion</th>
                <th>Telefonos</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cliente in Model)
            {
                <tr>
                    <td>@cliente.Cedula</td>
                    <td>@cliente.NombreCompleto</td>
                    <td>@cliente.CorreoElectronico</td>
                    <td>@cliente.Direccion</td>
                    <td>
                        @foreach (var telefono in cliente.Telefonos)
                        {
                            <span class="badge text-bg-light text-dark border me-1">@telefono.Tipo: @telefono.Numero</span>
                        }
                    </td>
                    <td class="text-end">
                        @* Estos botones quedan conectados a acciones vacias para que el resto del grupo implemente cada pantalla. *@
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Clientes" asp-action="Detalle" asp-route-id="@cliente.Id">Detalle</a>
                        <a class="btn btn-sm btn-outline-warning" asp-controller="Clientes" asp-action="Modificar" asp-route-id="@cliente.Id">Modificar</a>
                        <a class="btn btn-sm btn-outline-danger" asp-controller="Clientes" asp-action="Borrar" asp-route-id="@cliente.Id">Borrar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
