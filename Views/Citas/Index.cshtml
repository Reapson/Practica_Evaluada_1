@model List<Practica_Evaluada_1.Models.Cita>

@{
    ViewData["Title"] = "Listado de citas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Listado de citas</h1>
        <p class="text-muted mb-0">Citas registradas con cliente y vehiculo asociados.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Citas" asp-action="Registrar">Registrar cita</a>
</div>

@if (TempData["Mensaje"] is not null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Cliente</th>
                <th>Vehiculo</th>
                <th>Fecha y hora</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cita in Model)
            {
                <tr>
                    <td>@cita.Cliente?.NombreCompleto</td>
                    <td>@cita.Vehiculo?.Placa</td>
                    <td>@cita.FechaCita.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <span class="badge text-bg-light text-dark border me-1">@cita.Estado</span>
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-warning" asp-controller="Citas" asp-action="Modificar" asp-route-id="@cita.Id">Modificar</a>
                        <form method="post" asp-controller="Citas" asp-action="Borrar" asp-route-id="@cita.Id" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('æEstįs seguro de que deseas borrar esta cita?')">Borrar</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
