@model List<Practica_Evaluada_1.Models.Vehiculo>

@{
    ViewData["Title"] = "Listado de vehiculos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Listado de vehiculos</h1>
        <p class="text-muted mb-0">Vehiculos registrados y cliente asociado.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Vehiculos" asp-action="Registrar">Registrar vehiculo</a>
</div>

<input type="hidden" id="mensajeExito" value="@TempData["Mensaje"]" />

<div class="table-responsive">
    <table id="tablaVehiculos" class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Placa</th>
                <th>Marca</th>
                <th>Modelo</th>
                <th>Anio</th>
                <th>Color</th>
                <th>Cliente</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var vehiculo in Model)
            {
                <tr>
                    <td>@vehiculo.Placa</td>
                    <td>@vehiculo.Marca</td>
                    <td>@vehiculo.Modelo</td>
                    <td>@vehiculo.Anio</td>
                    <td>@vehiculo.Color</td>
                    <td>@vehiculo.Cliente?.NombreCompleto</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-warning" asp-controller="Vehiculos" asp-action="Modificar" asp-route-id="@vehiculo.Id">Modificar</a>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#borrarVehiculoModal"
                                data-vehiculo-id="@vehiculo.Id"
                                data-vehiculo-placa="@vehiculo.Placa">
                            Borrar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="borrarVehiculoModal" tabindex="-1" aria-labelledby="borrarVehiculoModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Borrar" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="vehiculoIdBorrar" name="id" />

                <div class="modal-header">
                    <h2 class="modal-title fs-5" id="borrarVehiculoModalLabel">Borrar vehiculo</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    Esta accion borrara el vehiculo con placa <strong id="vehiculoPlacaBorrar"></strong>.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Borrar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('#tablaVehiculos').DataTable({
                language: {
                    search: 'Buscar:',
                    lengthMenu: 'Mostrar _MENU_ registros',
                    info: 'Mostrando _START_ a _END_ de _TOTAL_ registros',
                    infoEmpty: 'No hay registros disponibles',
                    zeroRecords: 'No se encontraron vehiculos',
                    paginate: {
                        first: 'Primero',
                        last: 'Ultimo',
                        next: 'Siguiente',
                        previous: 'Anterior'
                    }
                }
            });

            const mensaje = $('#mensajeExito').val();

            if (mensaje) {
                Swal.fire({
                    icon: 'success',
                    title: mensaje,
                    timer: 1800,
                    showConfirmButton: false
                });
            }

            $('#borrarVehiculoModal').on('show.bs.modal', function (event) {
                const boton = $(event.relatedTarget);
                $('#vehiculoIdBorrar').val(boton.data('vehiculo-id'));
                $('#vehiculoPlacaBorrar').text(boton.data('vehiculo-placa'));
            });
        });
    </script>
}
