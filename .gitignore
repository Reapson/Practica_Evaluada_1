## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.user
*.userprefs

# Visual Studio cache/options directory
.vs/
.vscode/

# Visual Studio Code
*.code-workspace

# Rider
.idea/
*.sln.iml
*.swp
*.swo
*~

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# NuGet
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets
.nuget/
packages/

# Local NuGet repository
~/.nuget/

# Visual Studio cache directory
.vs/

# Resharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# TestResults
TestResults/
*.trx
*.coverage

# User-specific files (MonoDevelop/Xamarin Studio)
.monodevelop/
.xcodeproj/
*.userprefs

# Mono auto generated files
mono_crash.*

# Build folders
artifacts/

# Files built by Visual Studio
*.obj
*.exe
*.pdb
*.user
*.aps
*.pch
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Chutzpah Test files
_Chutzpah*

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JetBrains Rider
.idea/
*.sln.iml

# VS Code extensions
.vscode/extensions.json

# Local environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# IDE files
*.swp
*.swo
*~
.#*

# Application Insights
ApplicationInsights.config
Connected Services/

# SQL Server files
*.mdf
*.ldf
*.ndf

# Entity Framework
*.edmx.diagram

# BeatPulse healthcheck temp database
healthchecksdb

# Backup files
*.bak
*.backup
*.tmp

# Temporary web assembly cache
wwwroot/.dist/
